{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "node",
  "bump-minor-pre-major": true,
  "bump-patch-for-minor-pre-major": true,
  "include-v-in-tag": true,
  "include-component-in-tag": false,
  "changelog-sections": [
    { "type": "feat", "section": "Features" },
    { "type": "fix", "section": "Bug Fixes" },
    { "type": "perf", "section": "Performance" },
    { "type": "refactor", "section": "Code Refactoring" },
    { "type": "docs", "section": "Documentation" },
    { "type": "chore", "section": "Miscellaneous" },
    { "type": "security", "section": "Security" },
    { "type": "ci", "section": "CI/CD" },
    { "type": "test", "section": "Tests" }
  ],
  "packages": {
    ".": {
      "component": "eidolon",
      "changelog-path": "CHANGELOG.md",
      "initial-version": "0.1.0"
    },
    "packages/protocol": {
      "component": "protocol",
      "changelog-path": "packages/protocol/CHANGELOG.md"
    },
    "packages/core": {
      "component": "core",
      "changelog-path": "packages/core/CHANGELOG.md"
    },
    "packages/cli": {
      "component": "cli",
      "changelog-path": "packages/cli/CHANGELOG.md"
    },
    "packages/test-utils": {
      "component": "test-utils",
      "changelog-path": "packages/test-utils/CHANGELOG.md"
    },
    "apps/desktop": {
      "component": "desktop",
      "changelog-path": "apps/desktop/CHANGELOG.md",
      "extra-files": [
        {
          "type": "json",
          "path": "src-tauri/tauri.conf.json",
          "jsonpath": "$.version"
        },
        {
          "type": "toml",
          "path": "src-tauri/Cargo.toml",
          "jsonpath": "$.package.version"
        }
      ]
    },
    "apps/web": {
      "component": "web",
      "changelog-path": "apps/web/CHANGELOG.md"
    }
  }
}
