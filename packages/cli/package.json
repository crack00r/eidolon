{
  "name": "@eidolon-ai/cli",
  "version": "0.1.8",
  "type": "module",
  "description": "CLI for Eidolon -- autonomous, self-learning AI assistant daemon",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/crack00r/eidolon.git",
    "directory": "packages/cli"
  },
  "keywords": [
    "ai",
    "assistant",
    "daemon",
    "claude",
    "self-learning",
    "memory",
    "cli"
  ],
  "main": "dist/eidolon",
  "types": "src/index.ts",
  "bin": {
    "eidolon": "./dist/eidolon"
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target bun",
    "prepublishOnly": "bun build src/index.ts --outfile dist/eidolon --target bun",
    "test": "bun test src/",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/"
  },
  "dependencies": {
    "@eidolon/core": "workspace:*",
    "@eidolon/protocol": "workspace:*",
    "commander": "^13"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@types/bun": "^1.2.0",
    "typescript": "^5.7"
  },
  "engines": {
    "bun": ">=1.1.0"
  }
}
